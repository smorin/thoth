"""Development entry-point wrapper for thoth.

This script is used for local development and backward compatibility.
When installed via PyPI, the `thoth` command is provided by the package
entry point defined in pyproject.toml.
"""
import sys
from pathlib import Path

# Add src/ to sys.path so the local package is importable without installation
sys.path.insert(0, str(Path(__file__).parent / "src"))

from thoth.__main__ import main  # noqa: E402

main()
