[0.710, "o", "\u001b[3m                                    Available Providers                                    \u001b[0m\r\n╭───────────────┬────────────┬───────────────────────────┬────────────────────────────────╮\r\n│\u001b[1m \u001b[0m\u001b[1mProvider     \u001b[0m\u001b[1m \u001b[0m│\u001b[1m \u001b[0m\u001b[1mStatus    \u001b[0m\u001b[1m \u001b[0m│\u001b[1m \u001b[0m\u001b[1mDescription              \u001b[0m\u001b[1m \u001b[0m│\u001b[1m \u001b[0m\u001b[1mModel Cache                   \u001b[0m\u001b[1m \u001b[0m│\r\n├───────────────┼────────────┼───────────────────────────┼────────────────────────────────┤\r\n│\u001b[36m \u001b[0m\u001b[36mopenai       \u001b[0m\u001b[36m \u001b[0m│ \u001b[32m✓ Ready\u001b[0m    │\u001b[2m \u001b[0m\u001b[2mOpenAI GPT models        \u001b[0m\u001b[2m \u001b[0m│\u001b[2m \u001b[0m\u001b[2m5 days old (refresh in 2 days)\u001b[0"]
[0.000, "o", "m\u001b[2m \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36mperplexity   \u001b[0m\u001b[36m \u001b[0m│ \u001b[32m✓ Ready\u001b[0m    │\u001b[2m \u001b[0m\u001b[2mPerplexity Sonar         \u001b[0m\u001b[2m \u001b[0m│\u001b[2m \u001b[0m\u001b[2mN/A                           \u001b[0m\u001b[2m \u001b[0m│\r\n│\u001b[36m               \u001b[0m│            │\u001b[2m \u001b[0m\u001b[2m(web-grounded synchronous\u001b[0m\u001b[2m \u001b[0m│\u001b[2m                                \u001b[0m│\r\n│\u001b[36m               \u001b[0m│            │\u001b[2m \u001b[0m\u001b[2msearch)                  \u001b[0m\u001b[2m \u001b[0m│\u001b[2m                                \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36mgemini       \u001b[0m\u001b[36m \u001b[0m│ \u001b[32m✓ Ready\u001b[0m    │\u001b[2m \u001b[0m\u001b[2mGemini 2.5 (web-grounded \u001b[0m\u001b[2m \u001b[0m│\u001b[2m \u001b[0m\u001b[2mN/A                           \u001b[0m\u001b[2m \u001b[0m│\r\n│\u001b[36m               \u001b[0m│            │\u001b[2m \u001b[0m\u001b[2msynchronous search with  \u001b[0m\u001b[2m \u001b[0m│\u001b[2m                                \u001b[0m│\r\n│\u001b[36m               \u001b[0m│            │\u001b[2m \u001b[0m\u001b[2moptional thinking)       \u001b[0m\u001b[2m \u001b[0m│\u001b[2m                                \u001b[0m│\r\n│\u001b[36m \u001b[0m\u001b[36mmock         \u001b[0m\u001b[36m \u001b[0m│ \u001b[31m"]
