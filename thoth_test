class InteractiveTestRunner:
    """Handles pexpect-based interactive tests"""

    def __init__(self, verbose: bool = False):
        self.verbose = verbose

    def strip_ansi(self, text: str) -> str:
        """Remove ANSI escape codes from text for easier matching"""
        return re.sub(r"\x1b\[[0-9;]*[A-Za-z]", "", text)

    def run_interactive_test(self, test_case: TestCase) -> TestResult:
        """Execute an interactive test using pexpect"""
        start_time = time.time()

        # Set up environment
        test_env = os.environ.copy()
        test_env["COLUMNS"] = "80"  # Standard terminal width

        # Add test-specific environment variables
        if test_case.env:
            test_env.update(test_case.env)

        # Add terminal-specific environment if provided
        if test_case.terminal_env:
            test_env.update(test_case.terminal_env)

        # Set up API key if needed
        if test_case.provider:
            api_key = generate_mock_api_key() if test_case.provider == "mock" else ""
            if test_case.provider == "mock":
                test_env["MOCK_API_KEY"] = api_key
                # Interactive mock tests submit work that completes in ~0.1s, so
                # keep polling tight and let the child exit naturally.
                test_env.setdefault("THOTH_POLL_INTERVAL", "1")
            elif test_case.provider == "openai":
                test_env["OPENAI_API_KEY"] = os.getenv("OPENAI_API_KEY", "")
            elif test_case.provider == "perplexity":
                test_env["PERPLEXITY_API_KEY"] = os.getenv("PERPLEXITY_API_KEY", "")

        try:
            # Spawn the interactive process
            child = pexpect.spawn(
                test_case.command[0],
                args=test_case.command[1:] if len(test_case.command) > 1 else [],
                env=test_env,
                encoding="utf-8",
                timeout=test_case.timeout,
                dimensions=(24, 80),  # Standard terminal size
            )

            if self.verbose:
                child.logfile = sys.stdout

            # Wait for initial prompt/ready state
            # Most interactive tests should start with Thoth Interactive Mode
            try:
                child.expect("Thoth Interactive Mode", timeout=5)
            except (pexpect.TIMEOUT, pexpect.EOF):
                # Some tests might not show this, continue anyway
                pass

            # Execute the interactive scenario
            if test_case.interactive_scenario:
                for i, (expect_pattern, send_input) in enumerate(test_case.interactive_scenario):
                    if expect_pattern is not None:
                        try:
                            child.expect(expect_pattern, timeout=INTERACTIVE_STEP_TIMEOUT)
                            if self.verbose:
                                console.print(
                                    f"✓ Step {i + 1}: Found pattern: {expect_pattern[:50]}"
                                )
                        except pexpect.TIMEOUT:
                            error_msg = f"Step {i + 1}: Timeout waiting for: {expect_pattern}"
                            return TestResult(
                                test_id=test_case.test_id,
                                passed=False,
                                duration=time.time() - start_time,
                                stdout=child.before or "",
                                stderr=error_msg,
                                exit_code=-1,
                                error_message=error_msg,
                            )
                        except pexpect.EOF:
                            # EOF might be expected for Ctrl+C tests
                            if (
                                "exit" not in str(expect_pattern).lower()
                                and "eof" not in str(expect_pattern).lower()
                            ):
                                error_msg = f"Step {i + 1}: Unexpected EOF"
                                return TestResult(
                                    test_id=test_case.test_id,
                                    passed=False,
                                    duration=time.time() - start_time,
                                    stdout=child.before or "",
                                    stderr=error_msg,
                                    exit_code=-1,
                                    error_message=error_msg,
                                )

                    if send_input is not None:
                        child.send(send_input)
                        if self.verbose:
                            console.print(f"✓ Step {i + 1}: Sent input: {repr(send_input[:20])}")
                        time.sleep(0.1)  # Small delay for processing

            # Try to exit cleanly if not already done
            try:
                if child.isalive():
                    try:
                        child.expect(pexpect.EOF, timeout=INTERACTIVE_COMPLETION_TIMEOUT)
                    except pexpect.TIMEOUT:
                        child.send("/exit\r")
                        child.expect(pexpect.EOF, timeout=2)
            except Exception:
                pass  # Process might have already exited

            # Get final output
            stdout = child.before or ""

            # Close the child process
            child.close(force=True)
            if child.exitstatus is not None:
                exit_code = child.exitstatus
            elif child.signalstatus is not None:
                exit_code = -child.signalstatus  # negative => killed by signal
            else:
                exit_code = -1

            duration = time.time() - start_time

            # Create result
            result = TestResult(
                test_id=test_case.test_id,
                passed=True,
                duration=duration,
                stdout=stdout,
                stderr="",
                exit_code=exit_code,
            )

            # Validate exit code if specified
            if exit_code != test_case.expected_exit_code:
                result.passed = False
                result.error_message = (
                    f"Expected exit code {test_case.expected_exit_code}, got {exit_code}"
                )
                return result

            # Validate expected patterns in output if specified
            if test_case.expected_stdout_patterns:
                for pattern in test_case.expected_stdout_patterns:
                    if not re.search(pattern, stdout, re.MULTILINE | re.DOTALL):
                        result.passed = False
                        result.error_message = f"Pattern not found: {pattern}"
                        break

            return result

        except Exception as e:
            # Handle specific exceptions
            if "Input/output error" in str(e) and test_case.test_id in ["INT-06"]:
                # Expected for Ctrl+C test
                return TestResult(
                    test_id=test_case.test_id,
                    passed=True,
                    duration=time.time() - start_time,
                    stdout="",
                    stderr="Process terminated as expected",
                    exit_code=0,
                )

            return TestResult(
                test_id=test_case.test_id,
                passed=False,
                duration=time.time() - start_time,
                stdout="",
                stderr=str(e),
                exit_code=-1,
                error_message=f"Test failed with error: {e}",
            )


def print_list_tsv(tests: list[TestCase]) -> None:
    for t in tests:
        provider = t.provider or "none"
        sys.stdout.write(f"{t.test_id}\t{provider}\t{t.test_type}\t{t.description}\n")


def print_list_json(tests: list[TestCase]) -> None:
    payload = [
        {
            "test_id": t.test_id,
            "provider": t.provider,
            "test_type": t.test_type,
            "description": t.description,
            "is_interactive": bool(getattr(t, "is_interactive", False)),
        }
        for t in tests
    ]
    sys.stdout.write(json.dumps(payload) + "\n")


def serialize_run_report(runner: "TestRunner", invocation: list[str]) -> dict[str, Any]:
    started = getattr(runner, "_started_at_iso", None)
    finished = datetime.now(tz=UTC).isoformat().replace("+00:00", "Z")
    duration_total = time.time() - runner.start_time

    counts = {
        "total": len(runner.results),
        "passed": sum(1 for r in runner.results if r.passed and not r.skipped),
        "failed": sum(1 for r in runner.results if not r.passed),
        "skipped": sum(1 for r in runner.results if r.skipped),
        "api_key_failures": sum(1 for r in runner.results if not r.passed and r.is_api_key_failure),
    }

    test_case_by_id = {tc.test_id: tc for tc in runner.filtered_tests}
    tests_payload = []
    for r in runner.results:
        tc = test_case_by_id.get(r.test_id)
        include_output = not r.passed and not r.skipped
        tests_payload.append(
            {
                "test_id": r.test_id,
                "description": tc.description if tc else "",
                "provider": tc.provider if tc else None,
                "test_type": tc.test_type if tc else "subprocess",
                "passed": r.passed,
                "skipped": r.skipped,
                "duration_seconds": round(r.duration, 3),
                "exit_code": r.exit_code,
                "error_message": r.error_message,
                "is_api_key_failure": r.is_api_key_failure,
                "requested_but_filtered": bool(getattr(tc, "_requested_but_filtered", False))
                if tc
                else False,
                "stdout": r.stdout if include_output else None,
                "stderr": r.stderr if include_output else None,
            }
        )

    return {
        "schema_version": REPORT_SCHEMA_VERSION,
        "started_at": started,
        "finished_at": finished,
        "duration_total_seconds": round(duration_total, 3),
        "invocation": invocation,
        "requested_providers": runner.requested_providers,
        "counts": counts,
        "tests": tests_payload,
    }


def write_cache_atomic(payload: dict[str, Any], path: Path = CACHE_FILE) -> None:
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        tmp = path.with_suffix(path.suffix + ".tmp")
        tmp.write_text(json.dumps(payload, indent=2))
        os.replace(tmp, path)
    except OSError as exc:
        console.print(f"[yellow]Warning: could not write {path}: {exc}[/yellow]")


def read_last_failed(path: Path = CACHE_FILE) -> list[str]:
    """Return test_ids of failing tests from the last run cache.

    Raises FileNotFoundError if the cache is missing OR unreadable for any
    reason (corrupt JSON, wrong schema, permission error) — callers only
    need to handle one case. Returns [] if the cache parses cleanly but
    contains no failures.
    """
    try:
        payload = json.loads(path.read_text())
    except FileNotFoundError:
        raise  # keep the pristine "No such file or directory" message
    except (json.JSONDecodeError, OSError) as exc:
        raise FileNotFoundError(f"cache at {path} unreadable: {exc}") from exc
    if not isinstance(payload, dict) or payload.get("schema_version") != REPORT_SCHEMA_VERSION:
        raise FileNotFoundError(f"cache at {path} has unknown schema")
    tests = payload.get("tests") or []
    return [
        t["test_id"]
        for t in tests
        if isinstance(t, dict) and "test_id" in t and not t.get("passed", True)
    ]


def print_fenced_failure(result: TestResult, test_case: TestCase | None) -> None:
    desc = test_case.description if test_case else ""
    sys.stdout.write(f"===BEGIN FAILURE {result.test_id}===\n")
    sys.stdout.write(f"Test: {result.test_id} — {desc}\n")
    sys.stdout.write(f"Duration: {result.duration:.2f}s\n")
    sys.stdout.write(f"Exit code: {result.exit_code}\n")
    sys.stdout.write(f"Error: {result.error_message or ''}\n")
    sys.stdout.write("--- STDOUT ---\n")
    stdout = result.stdout or ""
    sys.stdout.write(stdout + ("\n" if not stdout.endswith("\n") else ""))
    sys.stdout.write("--- STDERR ---\n")
    stderr = result.stderr or ""
    sys.stdout.write(stderr + ("\n" if not stderr.endswith("\n") else ""))
    sys.stdout.write(f"===END FAILURE {result.test_id}===\n")


# ============================================================================
# Selection Resolver
# ============================================================================


def resolve_selection(
    all_tests: list[TestCase],
    *,
    test: str | None,
    provider_filter: list[str] | None,
    interactive: bool,
    skip_interactive: bool,
    ids: list[str],
    last_failed: bool,
) -> tuple[list[TestCase], list[str]]:
    """Pure filter-composition for main().

    Returns (selected_tests, warnings). When ``ids`` is non-empty it short-
    circuits the other filters: each named test runs even if it would have
    been excluded by --provider/--interactive/--skip-interactive, and a
    warning is emitted plus the TestCase is annotated with
    ``_requested_but_filtered = True`` so downstream consumers (JSON report)
    can surface the mismatch. ``last_failed`` is reserved for Task 6.
    """
    warnings: list[str] = []

    if ids:
        by_id = {t.test_id: t for t in all_tests}
        selected: list[TestCase] = []
        for wanted in ids:
            t = by_id.get(wanted)
            if t is None:
                warnings.append(f"--id {wanted} not found, ignoring")
                continue
            mismatch_reasons: list[str] = []
            if provider_filter and t.provider and t.provider not in provider_filter:
                mismatch_reasons.append(
                    f"provider={t.provider} not in --provider {provider_filter}"
                )
            if interactive and not getattr(t, "is_interactive", False):
                mismatch_reasons.append("not an interactive test but --interactive set")
            if skip_interactive and getattr(t, "is_interactive", False):
                mismatch_reasons.append("interactive test but --skip-interactive set")
            t._requested_but_filtered = bool(mismatch_reasons)
            if mismatch_reasons:
                warnings.append(
                    f"--id {wanted} runs despite filter mismatch: {'; '.join(mismatch_reasons)}"
                )
            selected.append(t)
        return selected, warnings

    selected = list(all_tests)
    if interactive:
        selected = [t for t in selected if getattr(t, "is_interactive", False)]
    if skip_interactive:
        selected = [t for t in selected if not getattr(t, "is_interactive", False)]
    if test:
        needle = test
        selected = [
            t for t in selected if needle in t.test_id or needle.lower() in t.description.lower()
        ]
    if provider_filter:
        kept = []
        for t in selected:
            if not t.provider:
                kept.append(t)
            elif t.provider in provider_filter:
                kept.append(t)
        selected = kept
    for t in selected:
        t._requested_but_filtered = False
    return selected, warnings


