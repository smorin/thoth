def _run_thoth_subprocess(
    args: list[str], env_overrides: dict[str, str], timeout: int = 30
) -> tuple[int, str, str]:
    """Run the thoth CLI in a subprocess and return (exit_code, stdout, stderr)."""
    cmd_env = os.environ.copy()
    cmd_env.update(env_overrides)
    cmd_env.setdefault("MOCK_API_KEY", generate_mock_api_key())
    cmd_env["COLUMNS"] = "200"

    result = subprocess.run(
        [THOTH_EXECUTABLE, *args],
        env=cmd_env,
        capture_output=True,
        text=True,
        timeout=timeout,
    )
    return result.returncode, result.stdout, result.stderr


def _extract_resume_id(output: str) -> str:
    """Pull an operation ID out of a 'Resume with: thoth --resume <id>' hint."""
    match = re.search(
        r"thoth --resume\s+(research-\d{8}-\d{6}-[a-f0-9]{16})", output
    )
    if not match:
        raise AssertionError(f"resume hint not found in output: {output!r}")
    return match.group(1)


def _res_01() -> None:
    """RES-01: Recoverable failure -> resume reconnects and completes."""
    cleanup_test_files(["*_mock_*.md"])
    exit_code, stdout, stderr = _run_thoth_subprocess(
        ["res01 first", "--provider", "mock"],
        {"THOTH_MOCK_BEHAVIOR": "flake:10", "THOTH_POLL_INTERVAL": "0.1"},
    )
    combined = stdout + stderr
    assert exit_code != 0, f"expected non-zero on flake exhaustion, got {exit_code}"
    assert "This failure is recoverable" in combined, (
        f"recoverable hint missing: {combined!r}"
    )
    op_id = _extract_resume_id(combined)

    checkpoint = load_checkpoint_data(op_id)
    assert checkpoint.get("failure_type") == "recoverable", (
        f"expected failure_type=recoverable in checkpoint, got {checkpoint!r}"
    )
    assert checkpoint["providers"]["mock"].get("job_id"), (
        f"expected job_id persisted in checkpoint, got {checkpoint!r}"
    )

    try:
        exit_code2, stdout2, stderr2 = _run_thoth_subprocess(
            ["--resume", op_id],
            {"THOTH_MOCK_BEHAVIOR": "default", "THOTH_POLL_INTERVAL": "0.1"},
        )
        combined2 = stdout2 + stderr2
        assert exit_code2 == 0, (
            f"expected successful resume, got exit={exit_code2}\n"
            f"stdout={stdout2!r}\nstderr={stderr2!r}"
        )
        assert "Research completed" in combined2, (
            f"expected completion on resume: {combined2!r}"
        )
    finally:
        remove_test_checkpoint(op_id)
        cleanup_test_files(["*_mock_*.md"])


