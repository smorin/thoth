def find_latest_output_file(pattern: str = "*_*_*_*_*.md") -> Path | None:
    """Find the most recently created output file matching pattern"""
    files = sorted(Path(".").glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
    return files[0] if files else None


_TEST_CONFIG_HOME: Path | None = None
_TEST_CONFIG_HOME_LOCK = threading.Lock()


def _ensure_test_config_home() -> Path:
    """Create a per-run temp XDG root and propagate it to subprocesses.

    Thoth now follows XDG split: config under XDG_CONFIG_HOME, checkpoints
    under XDG_STATE_HOME, model cache under XDG_CACHE_HOME. Point all three
    at the same tmpdir so tests get an isolated unified tree.
    """
    global _TEST_CONFIG_HOME
    with _TEST_CONFIG_HOME_LOCK:
        if _TEST_CONFIG_HOME is None:
            _TEST_CONFIG_HOME = Path(tempfile.mkdtemp(prefix="thoth-test-"))
            os.environ["XDG_CONFIG_HOME"] = str(_TEST_CONFIG_HOME)
            os.environ["XDG_STATE_HOME"] = str(_TEST_CONFIG_HOME)
            os.environ["XDG_CACHE_HOME"] = str(_TEST_CONFIG_HOME)
            atexit.register(shutil.rmtree, str(_TEST_CONFIG_HOME), True)
        return _TEST_CONFIG_HOME


def _prepare_test_isolation(
    test_case: TestCase,
) -> tuple[Path, list[str], dict[str, str], Path | None]:
    """Create per-test tmpdir and return (tmpdir, command, env, output_base).

    ``output_base`` is the tmpdir when we injected ``--output-dir``, else None
    (callers should resolve expected_files against CWD in that case).
    """
    tmpdir = Path(tempfile.mkdtemp(prefix=f"thoth-test-{test_case.test_id}-"))
    cmd = list(test_case.command)
    output_base: Path | None = None
    # Only inject --output-dir for tests that actually run a provider and produce
    # output files. Tests without a provider (CLI errors, --help, etc.) can parse
    # the injected args incorrectly (e.g. `thoth --mode --output-dir X` would
    # consume --output-dir as the --mode value). Also skip if the test already
    # passes -o/--output-dir or uses --project (which routes output under
    # base_output_dir/<project>/ and is overridden by --output-dir).
    if test_case.provider and not any(a in cmd for a in ("-o", "--output-dir", "--project")):
        cmd += ["--output-dir", str(tmpdir)]
        output_base = tmpdir
    env = dict(test_case.env)
    env.setdefault("XDG_CONFIG_HOME", str(tmpdir))
    env.setdefault("XDG_STATE_HOME", str(tmpdir))
    env.setdefault("XDG_CACHE_HOME", str(tmpdir))
    # uv falls back to XDG_CACHE_HOME when UV_CACHE_DIR is unset; pointing it at
    # the per-test tmpdir would force a fresh package re-download on every test
    # (and break T-SIG-01's 1.5s SIGINT timing). Keep uv on the shared cache.
    env.setdefault("UV_CACHE_DIR", str(Path.home() / ".cache" / "uv"))
    return tmpdir, cmd, env, output_base


def get_checkpoint_dir(config_home: Path) -> Path:
    """Return <config_home>/thoth/checkpoints for the given per-test config home."""
    return config_home / "thoth" / "checkpoints"


def create_test_checkpoint(
    operation_id: str,
    config_home: Path,
    status: str = "completed",
    **overrides,
) -> Path:
    """Create a valid checkpoint file for testing"""
    checkpoint_dir = get_checkpoint_dir(config_home)
    checkpoint_dir.mkdir(parents=True, exist_ok=True)

    now = datetime.now()
    data = {
        "id": operation_id,
        "prompt": "test checkpoint prompt",
        "mode": "default",
        "status": status,
        "created_at": (now - timedelta(minutes=5)).isoformat(),
        "updated_at": now.isoformat(),
        "providers": {"mock": {"status": "completed"}},
        "output_paths": {},
        "error": None,
        "progress": 1.0 if status == "completed" else 0.0,
        "project": None,
        "input_files": [],
        "failure_type": None,
    }
    data.update(overrides)

    checkpoint_file = checkpoint_dir / f"{operation_id}.json"
    with open(checkpoint_file, "w") as f:
        json.dump(data, f, indent=2)
    return checkpoint_file


def create_corrupted_checkpoint(operation_id: str, config_home: Path) -> Path:
    """Create a corrupted checkpoint file for testing"""
    checkpoint_dir = get_checkpoint_dir(config_home)
    checkpoint_dir.mkdir(parents=True, exist_ok=True)

    checkpoint_file = checkpoint_dir / f"{operation_id}.json"
    with open(checkpoint_file, "w") as f:
        f.write("{invalid json content, not valid at all!!!")
    return checkpoint_file


def remove_test_checkpoint(operation_id: str, config_home: Path) -> None:
    """Remove a test checkpoint file"""
    checkpoint_file = get_checkpoint_dir(config_home) / f"{operation_id}.json"
    if checkpoint_file.exists():
        checkpoint_file.unlink()


def extract_operation_id(output: str) -> str:
    """Extract an operation ID from CLI output."""
    match = re.search(r"Operation ID:\s*(research-\d{8}-\d{6}-[a-f0-9]{16})", output)
    if not match:
        raise AssertionError(f"operation ID not found in output: {output!r}")
    return match.group(1)


def load_checkpoint_data(operation_id: str, config_home: Path) -> dict[str, Any]:
    """Load a checkpoint file as JSON for assertions."""
    checkpoint_file = get_checkpoint_dir(config_home) / f"{operation_id}.json"
    if not checkpoint_file.exists():
        raise AssertionError(f"checkpoint not found: {checkpoint_file}")
    with open(checkpoint_file) as f:
        return json.load(f)


def validate_test_environment(
    test_api_keys: dict[str, str], requested_providers: list[str] | None = None
) -> None:
    """Validate test environment and show configuration"""
    console.print("\n[bold]Test Environment Configuration:[/bold]")

    # Always show mock status (it's always available)
    console.print(f"Mock API Key: {test_api_keys['mock'][:8]}... (auto-generated)")

    # If specific providers requested, validate only those
    if requested_providers:
        missing_keys = []
        for provider in requested_providers:
            if provider == "mock":
                continue  # Mock is always available
            elif provider == "openai":
                if test_api_keys["openai"]:
                    console.print(f"OpenAI API Key: {test_api_keys['openai'][:8]}... ✓")
                else:
                    console.print(
                        "[red]OpenAI API Key: Not set (required for requested tests)[/red]"
                    )
                    missing_keys.append("OPENAI_API_KEY")
            elif provider == "perplexity":
                if test_api_keys["perplexity"]:
                    console.print(f"Perplexity API Key: {test_api_keys['perplexity'][:8]}... ✓")
                else:
                    console.print(
                        "[red]Perplexity API Key: Not set (required for requested tests)[/red]"
                    )
                    missing_keys.append("PERPLEXITY_API_KEY")

        if missing_keys:
            console.print(
                f"\n[red]Error: Missing required API keys: {', '.join(missing_keys)}[/red]"
            )
            console.print(
                "Please set the environment variables or remove these providers from your selection."
            )
            sys.exit(1)
    else:
        # Default behavior: show status of all providers
        if test_api_keys["openai"]:
            console.print(f"OpenAI API Key: {test_api_keys['openai'][:8]}... ✓")
        else:
            console.print("[yellow]OpenAI API Key: Not set (OpenAI tests will be skipped)[/yellow]")

        if test_api_keys["perplexity"]:
            console.print(f"Perplexity API Key: {test_api_keys['perplexity'][:8]}... ✓")
        else:
            console.print(
                "[yellow]Perplexity API Key: Not set (Perplexity tests will be skipped)[/yellow]"
            )

    console.print("")  # Blank line


